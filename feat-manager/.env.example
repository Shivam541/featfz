APP_ENV=development
HTTP_ADDR=:8080
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=feat_manager
DB_PASSWORD=feat_manager
DB_NAME=feat_manager
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Used by the migrate container inside docker compose.
MIGRATE_DATABASE_URL=mysql://feat_manager:feat_manager@tcp(mysql:3306)/feat_manager?multiStatements=true
